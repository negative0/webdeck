// This is your Prisma schema file,
generator client {
  provider      = "prisma-client-js"
  output        = "../generated/prisma"
  binaryTargets = ["native", "darwin", "darwin-arm64", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Auth models
model User {
  id         String         @id @default(uuid())
  email      String         @unique
  name       String?
  createdAt  DateTime       @default(now())
  identities UserIdentity[]
  deckButtons DeckButton[]
  decks      Deck[]
  isDeleted  Boolean        @default(false)

  @@index([email])
}

model UserIdentity {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider   String // 'Google', 'GitHub', 'EmailPassword', 'PhoneOTP', etc.
  providerId String // Provider's unique user ID (or email for email/password)
  metadata   Json? // Provider-specific data (passwordHash, tokens, profile data, etc.)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  isDeleted  Boolean  @default(false)

  @@unique([provider, providerId])
  @@index([userId])
}

model Deck {
  id          String   @id @default(uuid())
  name        String
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  buttons     DeckButton[]
  rows        Int      @default(3)
  cols        Int      @default(5)
  contextApp  String?
  contextUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isDeleted   Boolean  @default(false)

  @@index([userId])
}

model DeckButton {
  id        String   @id @default(uuid())
  label     String
  icon      String?
  command   String
  type      String   @default("COMMAND") // "COMMAND" or "SHORTCUT"
  checkCommand String?
  activeIcon   String?
  activeLabel  String?
  color     String?
  row       Int
  col       Int
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  deckId    String?
  deck      Deck?    @relation(fields: [deckId], references: [id], onDelete: SetNull)
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([deckId])
}
